{
  "name": "zipflow",
  "version": "1.2.4",
  "description": "Interactive terminal workflow for safely reviewing and applying source-code ZIP updates",
  "type": "module",
  "bin": {
    "zipflow": "./bin/zipflow.js"
  },
  "scripts": {
    "start": "node ./bin/zipflow.js",
    "check": "node ./scripts/check-source.js && node ./scripts/check-i18n.js",
    "test": "node --test",
    "verify": "npm run check && npm test",
    "release:check": "npm run verify && npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ignore": "^7.0.6",
    "picomatch": "^4.0.3",
    "terlio.js": "^1.1.3",
    "yauzl": "^3.2.0",
    "yazl": "^3.3.1"
  },
  "license": "MIT",
  "files": [
    "bin",
    "src",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "zip",
    "archive",
    "workflow",
    "terminal",
    "cli",
    "code-review",
    "rollback",
    "deployment"
  ],
  "os": [
    "darwin",
    "linux"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
